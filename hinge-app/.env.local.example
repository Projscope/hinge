# Supabase — get these from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Required for webhook handler (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — get these from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...   # $4/month price ID
STRIPE_PRICE_YEARLY=price_...    # $39/year price ID

# Optional — only needed to run migrations via scripts/migrate.mjs
# SUPABASE_ACCESS_TOKEN=your-personal-access-token
